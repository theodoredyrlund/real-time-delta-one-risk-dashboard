# ─────────────────────────────────────────────
#  Real-Time Delta One Risk Dashboard
#  Environment variables (copier en .env)
# ─────────────────────────────────────────────

ENVIRONMENT=dev

# Database
DB_TYPE=sqlite           # sqlite | postgresql
DB_PATH=data/dashboard.db
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=delta_one_db
# DB_USER=admin
# DB_PASSWORD=your_password

# Market data API (optionnel, yfinance est gratuit)
# ALPHA_VANTAGE_API_KEY=your_key_here
# TWELVE_DATA_API_KEY=your_key_here

# AWS (pour déploiement cloud)
# AWS_REGION=eu-west-1
# AWS_S3_BUCKET=delta-one-data
